{
  "name": "evm-counter",
  "version": "0.1.0",
  "description": "EVM deployment of the Counter contract using standard Hardhat + solc",
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "deploy:local": "npx hardhat ignition deploy ./ignition/modules/Counter.js --network local",
    "deploy:testnet": "npx hardhat ignition deploy ./ignition/modules/Counter.js --network polkadotTestnet",
    "verify": "npx hardhat verify --network polkadotTestnet"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "hardhat": "^2.27.0"
  }
}
